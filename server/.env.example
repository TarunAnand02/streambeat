NODE_ENV=PRODUCTION
PORT=5000

# Local MongoDB: mongodb://127.0.0.1:27017/youtube-portfolio
# Or a free MongoDB Atlas cluster connection string
MONGO_URI=mongodb://127.0.0.1:27017/youtube-portfolio

# Origin of the Vite dev server (client)
CLIENT_ORIGIN=http://localhost:5173

# Generate strong random values for these, e.g. `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_ACCESS_SECRET=changeme_access_secret
JWT_REFRESH_SECRET=changeme_refresh_secret

JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Optional. Only needed if connecting to a mongodb+srv:// URI (e.g. Atlas)
# fails with "querySrv ECONNREFUSED" on this network — some Windows/router
# DNS setups break Node's SRV lookups even though the OS resolver works
# fine. Uncomment and set to a public resolver to work around it.
# DNS_SERVERS=8.8.8.8,1.1.1.1
#
# Alternative: avoid the SRV lookup entirely by using Atlas's standard
# (non-SRV) connection string instead of mongodb+srv:// — in the Atlas UI,
# under Connect > Drivers, there's a "using SRV connection string" toggle
# you can switch off to get a mongodb:// URI with explicit shard hosts.

# Optional. Only needed for the "Import from YouTube" feature. Get one at
# https://console.cloud.google.com/ — enable "YouTube Data API v3", then
# APIs & Services > Credentials > Create Credentials > API key ("Public
# data" access type). The rest of the app works fine without this set.
# YOUTUBE_API_KEY=

# Optional. Where uploaded video/thumbnail files are stored on LOCAL disk.
# Defaults to server/src/storage (fine for local dev). In production, point
# this at a mounted persistent volume (e.g. a Render Disk) so files survive
# redeploys — only relevant if you're NOT using cloud storage below.
# STORAGE_DIR=/data

# Optional S3-compatible cloud storage (Supabase Storage, Cloudflare R2,
# Backblaze B2, MinIO, ...) for video/thumbnail files. Set these instead of
# STORAGE_DIR when local disk isn't persistent (e.g. Render's free tier
# wipes local files on every redeploy) — uploads then go to the bucket
# instead, surviving redeploys. Leave unset to keep using local disk.
# STORAGE_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_BUCKET_NAME=streambeat-media

# Optional — preferred over SMTP below when set. Brevo (brevo.com, free
# tier, no card required) sends over plain HTTPS, which works even on hosts
# that block outbound SMTP ports (e.g. Render's free tier silently breaks
# SMTP). Verify a sender email in the Brevo dashboard first, then use that
# address here.
# BREVO_API_KEY=
# BREVO_SENDER_EMAIL=

# Optional SMTP fallback for sending real password-reset/verification
# emails (e.g. a free Gmail account with an App Password works fine —
# smtp.gmail.com, port 587), used only if BREVO_API_KEY is unset. Without
# either configured, these emails still "work" in development: the link is
# logged to this console and returned in the API response instead of
# actually being emailed.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Optional "Continue with Google/GitHub" sign-in — each provider is
# independently optional; the login/register pages simply don't show that
# button until both its id and secret are set. Get these from
# https://console.cloud.google.com/ (OAuth client) and
# https://github.com/settings/developers (OAuth App) respectively — set
# each provider's callback URL to <SERVER_ORIGIN>/api/auth/google/callback
# (or /github/callback).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# This server's own public base URL — used to build the OAuth callback URLs
# above. Defaults to http://localhost:<PORT>, which is correct for local
# dev. In production this MUST be set to the real deployed URL, or OAuth
# login will fail with a redirect_uri_mismatch the moment someone tries it
# (nothing else breaks, so this is easy to miss — the server logs a warning
# at boot if OAuth is configured but this isn't set).
# SERVER_ORIGIN=
